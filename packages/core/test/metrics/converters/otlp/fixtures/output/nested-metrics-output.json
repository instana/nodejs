{
  "resourceMetrics": [
    {
      "resource": {
        "attributes": [
          {
            "key": "telemetry.sdk.language",
            "value": {
              "stringValue": "nodejs"
            }
          },
          {
            "key": "telemetry.sdk.name",
            "value": {
              "stringValue": "@instana/collector"
            }
          },
          {
            "key": "service.name",
            "value": {
              "stringValue": "nodejs-service"
            }
          },
          {
            "key": "process.pid",
            "value": {
              "intValue": 12345
            }
          },
          {
            "key": "host.name",
            "value": {
              "stringValue": "host-abc-123"
            }
          }
        ]
      },
      "scopeMetrics": [
        {
          "scope": {
            "name": "@instana/collector",
            "version": "3.0.0"
          },
          "metrics": [
            {
              "name": "nodejs.memory.heapUsed",
              "sum": {
                "dataPoints": [
                  {
                    "asDouble": 50000000
                  }
                ]
              }
            },
            {
              "name": "nodejs.memory.heapTotal",
              "sum": {
                "dataPoints": [
                  {
                    "asDouble": 100000000
                  }
                ]
              }
            },
            {
              "name": "nodejs.cpu.usage",
              "sum": {
                "dataPoints": [
                  {
                    "asDouble": 45.5
                  }
                ]
              }
            },
            {
              "name": "activeHandles",
              "sum": {
                "dataPoints": [
                  {
                    "asDouble": 10
                  }
                ]
              }
            },
            {
              "name": "gc.minorGcs",
              "sum": {
                "dataPoints": [
                  {
                    "asDouble": 100
                  }
                ]
              }
            },
            {
              "name": "gc.majorGcs",
              "sum": {
                "dataPoints": [
                  {
                    "asDouble": 5
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}